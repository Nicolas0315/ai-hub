  "vol3": {
    "title": "非和声音・偶成和音・保続音・対位法的技法",
    "non_chord_tones": {
      "passing_tone": {
        "motion": "stepwise between chord tones",
        "accent": false
      },
      "neighbor_tone": {
        "motion": "step away and return",
        "accent": false
      },
      "appoggiatura": {
        "motion": "leap to, step away (resolve down)",
        "accent": true
      },
      "suspension": {
        "phases": [
          "preparation (consonant)",
          "suspension (dissonant on beat)",
          "resolution (step down)"
        ],
        "common": [
          "4-3",
          "7-6",
          "9-8",
          "2-3 (bass)"
        ]
      },
      "anticipation": {
        "motion": "arrives early before chord change"
      },
      "escape_tone": {
        "motion": "step to, leap away"
      },
      "pedal_point": {
        "motion": "sustained note (usually tonic or dominant in bass)"
      },
      "changing_tones": {
        "motion": "double neighbor: step up, skip down, step up (or reverse)"
      }
    },
    "chromatic_alteration": {
      "raised_notes": "creates leading tone effect toward target",
      "lowered_notes": "creates subdominant pull",
      "cross_relation": {
        "rule": "chromatic alteration must occur in SAME voice, not across voices",
        "exception": "bass to inner voice, or dim7 resolution"
      }
    },
    "pedal_and_ostinato": {
      "tonic_pedal": "sustained tonic in bass, harmonies move above",
      "dominant_pedal": "sustained dominant, builds tension",
      "double_pedal": "tonic + dominant sustained",
      "inverted_pedal": "sustained note in upper voice"
    },
    "contrapuntal_harmony": {
      "voice_count_changes": "2-6 voices, texture varies within piece",
      "imitation": "one voice echoes another at interval/time delay",
      "canon": "strict imitation throughout",
      "invertible_counterpoint": "double/triple counterpoint at 8ve/10th/12th"
    }
  },
