{
  "theory_sources": [
    "Kostka, S. & Payne, D. (2017). Tonal Harmony. McGraw-Hill. Ch. 9-13.",
    "Aldwell, E. & Schachter, C. (2018). Harmony and Voice Leading. Cengage. Ch. 6-8.",
    "島岡譲 (1964). 和声—理論と実習 I-III. 音楽之友社. (芸大和声)",
    "Hein, E. (2021). 'Lo-fi hip hop beats to study/relax to': The aesthetics of democratized music production. Popular Music, 40(3-4).",
    "Harrison, D. (1994). Harmonic Function in Chromatic Music. U Chicago Press.",
    "Levine, M. (1995). The Jazz Theory Book. Sher Music."
  ],
  "lofi_principles": [
    "Modal interchange (borrowed chords from parallel minor/major)",
    "Non-functional harmony: chords chosen for color, not resolution",
    "Loop-based = no teleological harmonic motion (no goal-directed cadence)",
    "7th/9th as default sonority (not as dissonance requiring resolution)",
    "Plagal > Authentic: IV→I motion preferred over V→I"
  ],
  "seventh_type_reference": {
    "maj7": {
      "quality": "major-major 7th",
      "dissonance": "low (半音差 B-C in Cmaj7, しかし柔らかい不協和)",
      "resolution_required": false,
      "explanation": "長7度は協和的不協和。ジャズ/ポピュラーでは色彩として定着。古典和声では非和声音扱い (Aldwell Ch.26)",
      "lofi_usage": "浮遊感・ノスタルジアの源泉。解決不要で自由にループ可能"
    },
    "m7": {
      "quality": "minor-minor 7th",
      "dissonance": "low-moderate",
      "resolution_required": false,
      "explanation": "短7度は比較的協和。ii7, iii7, vi7 で自然に出現。ジャズでは基本ボイシング (Kostka Ch.13)",
      "lofi_usage": "メランコリックな色彩。Am7→Dm7 等のm7連鎖がLofiの定番"
    },
    "dominant_7": {
      "quality": "major-minor 7th (dominant 7th)",
      "dissonance": "high (tritone between 3rd and 7th)",
      "resolution_required": true,
      "explanation": "三全音(トライトーン)を含む唯一の自然7th和音。解決先はI (Kostka Ch.9, 芸大和声 I §24)。解決なしは機能和声の違反",
      "lofi_usage": "⚠️ 要注意: V7→I の文脈でのみ使用。ループ内で浮遊させると古典的には破綻。ただしネオソウル/ジャズでは意図的に未解決で使う場合あり",
      "geidai_rule": "V7の第7音は必ず下行順次進行で解決 (芸大和声 I, §24-25)"
    },
    "m9": {
      "quality": "minor 9th (extended)",
      "dissonance": "moderate",
      "resolution_required": false,
      "explanation": "9thはテンション。ジャズ理論ではavailable tension (Mark Levine, Jazz Theory Book, 1995)",
      "lofi_usage": "最も「Lofi的」な響き。Am9→Dm9 の進行はジャンル定義的"
    },
    "half_dim7": {
      "quality": "half-diminished 7th (ø7)",
      "dissonance": "high",
      "resolution_required": true,
      "explanation": "V7の根音省略形として機能。iiø7→V7→i がminor ii-V-i (芸大和声 II §35)",
      "lofi_usage": "稀。使う場合はii→V文脈で"
    }
  },
