AUTH_SECRET=YOUR_AUTH_SECRET_HERE
# Add provider secrets here, managed by 1Password
# GITHUB_ID=
# GITHUB_SECRET=

# WebAuthn/Passkey Configuration
# WEBAUTHN_RP_ID="katala.io"        # Production RP ID
# WEBAUTHN_RP_NAME="Katala"         # Relying Party Name
# WEBAUTHN_ORIGIN="https://katala.io" # Origin URL
WEBAUTHN_RP_ID="localhost"          # Development RP ID
WEBAUTHN_RP_NAME="Katala (Dev)"     # Development RP Name
WEBAUTHN_ORIGIN="http://localhost:3000" # Development Origin

# HMAC Legacy (for backward compatibility)
HUMAN_LAYER_SIGNING_KEY=YOUR_SIGNING_KEY_HERE
