{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://katala.local/schemas/claim-ir-v1.schema.json",
  "title": "ClaimIR v1",
  "type": "object",
  "required": ["version", "source_modality", "payload", "quality"],
  "properties": {
    "version": { "const": "claim-ir-v1" },
    "source_modality": { "type": "string", "enum": ["text", "logic", "math", "code", "image", "audio", "binary"] },
    "payload": {
      "type": "object",
      "required": ["raw_text", "temporal", "paradigm", "category", "perspective", "opinion", "embodied"],
      "properties": {
        "raw_text": { "type": "string" },
        "temporal": { "type": "object" },
        "paradigm": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "array", "items": { "type": "string" } },
        "perspective": { "type": "array", "items": { "type": "string" } },
        "opinion": { "type": "array", "items": { "type": "string" } },
        "embodied": { "type": "object" }
      },
      "additionalProperties": true
    },
    "quality": {
      "type": "object",
      "required": ["mapping_completeness_loss", "mapping_fidelity_loss", "information_loss_ratio"],
      "properties": {
        "mapping_completeness_loss": { "type": "number", "minimum": 0, "maximum": 1 },
        "mapping_fidelity_loss": { "type": "number", "minimum": 0, "maximum": 1 },
        "information_loss_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  },
  "additionalProperties": true
}
