+def _sat_seed_portfolio_envs(vars_list: list[str], budget: int, var_activity: dict[str, int]) -> list[dict[str, bool]]:
+    if budget <= 0 or not vars_list:
+        return []
+
+    ranked = sorted(vars_list, key=lambda key: var_activity.get(key, 0), reverse=True)
+    top = ranked[: min(10, len(ranked))]
+    base_false = {name: False for name in vars_list}
+    base_true = {name: True for name in vars_list}
+
+    seen: set[tuple[int, ...]] = set()
+    out: list[dict[str, bool]] = []
+
+    def _add(env: dict[str, bool]) -> None:
+        if len(out) >= budget:
+            return
+        key = tuple(1 if env.get(name, False) else 0 for name in vars_list)
+        if key in seen:
+            return
+        seen.add(key)
+        out.append(dict(env))
+
+    _add(base_false)
+    _add(base_true)
+
+    for name in top:
+        env = dict(base_false)
+        env[name] = True
+        _add(env)
+
+    for name in top:
+        env = dict(base_true)
+        env[name] = False
+        _add(env)
+
+    for i in range(len(top)):
+        if len(out) >= budget:
+            break
+        for j in range(i + 1, len(top)):
+            env = dict(base_false)
+            env[top[i]] = True
+            env[top[j]] = True
+            _add(env)
+            if len(out) >= budget:
+                break
+
+    return _rank_envs_nn_qemu(vars_list, out)[:budget]
+
+
+def _sat_subsumption_pass(clauses: list[list[tuple[str, bool]]]) -> tuple[list[list[tuple[str, bool]]], int]:
+    if len(clauses) <= 1:
+        return clauses, 0
+
+    clause_sets = [set(clause) for clause in clauses]
+    order = sorted(range(len(clauses)), key=lambda idx: len(clause_sets[idx]))
+    removed: set[int] = set()
+
+    for pos, left in enumerate(order):
+        if left in removed:
+            continue
+        left_set = clause_sets[left]
+        for right in order[pos + 1 :]:
+            if right in removed:
+                continue
+            if left_set.issubset(clause_sets[right]):
+                removed.add(right)
+
+    if not removed:
+        return clauses, 0
+    return [clause for idx, clause in enumerate(clauses) if idx not in removed], len(removed)
+
