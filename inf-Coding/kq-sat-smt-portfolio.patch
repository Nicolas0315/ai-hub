+def _select_smt_portfolio(total_space: int, var_count: int, nn_rank_limit: int, exhaustive_limit: int) -> dict[str, Any]:
+    chunk_size = _safe_env_int("KQ_SMT_PORTFOLIO_CHUNK_SIZE", 384, 32)
+    inprocess_every = _safe_env_int("KQ_SMT_INPROCESS_EVERY", 1024, 64)
+    stream_switch = _safe_env_int("KQ_SMT_PORTFOLIO_STREAM_SWITCH", max(nn_rank_limit, min(exhaustive_limit * 2, 280000)), 1024)
+
+    if total_space <= nn_rank_limit:
+        return {
+            "strategy": "nn-ranked-enumeration",
+            "chunk_size": 0,
+            "inprocess_every": inprocess_every,
+        }
+    if total_space <= stream_switch or (var_count <= 8 and total_space <= exhaustive_limit * 2):
+        return {
+            "strategy": "chunked-nn-stream",
+            "chunk_size": chunk_size,
+            "inprocess_every": inprocess_every,
+        }
+    return {
+        "strategy": "plain-stream",
+        "chunk_size": chunk_size,
+        "inprocess_every": inprocess_every,
+    }
+
+
+def _iter_env_chunks(names: list[str], ranges: list[range], chunk_size: int):
+    raw_iter = product(*ranges)
+    while True:
+        block = list(islice(raw_iter, max(1, int(chunk_size))))
+        if not block:
+            break
+        yield [{k: int(v) for k, v in zip(names, values)} for values in block]
+
+
+def _smt_inprocess_decay(feature_bias: dict[str, float]) -> None:
+    for key in list(feature_bias.keys()):
+        cur = float(feature_bias.get(key, 0.0))
+        feature_bias[key] = max(-0.75, min(0.75, cur * 0.92))
+
+
+def _select_sat_portfolio(var_count: int, clause_count: int, internal: bool = False) -> dict[str, Any]:
+    inprocess_every = _safe_env_int("KQ_SAT_INPROCESS_EVERY", 96, 16)
+    if internal:
+        return {
+            "strategy": "internal-cdcl",
+            "prepass_budget": 0,
+            "prepass_exhaustive": False,
+            "inprocess_every": inprocess_every,
+        }
+
+    small_var_limit = _safe_env_int("KQ_SAT_PORTFOLIO_SMALL_VAR_LIMIT", 14, 4)
+    exhaustive_cap = _safe_env_int("KQ_SAT_PORTFOLIO_ENUM_CAP", 32768, 128)
+    prepass_budget = _safe_env_int("KQ_SAT_PORTFOLIO_PREPASS_BUDGET", 768, 0)
+    total_space = (1 << var_count) if var_count <= 30 else exhaustive_cap + 1
+
+    if var_count <= small_var_limit and total_space <= exhaustive_cap:
+        return {
+            "strategy": "nn-ranked-exhaustive-prepass",
+            "prepass_budget": int(total_space),
+            "prepass_exhaustive": True,
+            "inprocess_every": inprocess_every,
+        }
+    if prepass_budget > 0 and var_count <= (small_var_limit + 8) and clause_count <= 1024:
+        return {
+            "strategy": "nn-ranked-seed-prepass",
+            "prepass_budget": int(prepass_budget),
+            "prepass_exhaustive": False,
+            "inprocess_every": inprocess_every,
+        }
+    return {
+        "strategy": "cdcl-primary",
+        "prepass_budget": 0,
+        "prepass_exhaustive": False,
+        "inprocess_every": inprocess_every,
+    }
+
